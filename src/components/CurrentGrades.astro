---
import gradesData from "../data/grades.json";
import missingAssignmentsData from "../data/missing_assignments.json";
import fs from "fs/promises";
import path from "path";

type ScrapedAssignment = {
    earnedPoints: number;
    totalPoints: number;
    graded: boolean;
};

type ScrapedClass = {
    className: string;
    period: string;
    assignments: ScrapedAssignment[];
};

type MissingAssignment = {
    assignment_name: string;
    class_name: string;
    due_date: string;
    max_points: number | string;
};

type MissingAssignmentsData = {
    missing_assignments?: MissingAssignment[];
};

const data = gradesData.classes.map((classInfo) => ({
    className: classInfo.class_name,
    teacher: classInfo.teacher,
    q1_grade: classInfo.q1_grade,
    q1_letter_grade: classInfo.q1_letter_grade,
    q2_grade: classInfo.q2_grade,
    q2_letter_grade: classInfo.q2_letter_grade,
    period: classInfo.period,
    grade: classInfo.current_grade,
    lettergrade: classInfo.letter_grade,
}));
const metadata = {
    last_updated: gradesData.metadata.last_updated,
};

const normalizeClassName = (value: string): string =>
    value.trim().toLowerCase().replace(/[^a-z0-9]+/g, " ");
const classLookup = new Map(
    data.map((entry) => [normalizeClassName(entry.className), entry]),
);

const normalizeMissingDate = (value: string): string =>
    value.replace(/\u00a0/g, " ").replace(/\s*\(Q\d+\)/i, "").trim();

let scrapedClasses: ScrapedClass[] = [];
try {
    const scrapedPath = path.resolve("scraper", "detailed-grades.json");
    const raw = await fs.readFile(scrapedPath, "utf8");
    const parsed = JSON.parse(raw) as { classes?: ScrapedClass[] };
    scrapedClasses = parsed?.classes ?? [];
} catch (error) {
    scrapedClasses = [];
}
const scrapedByName = new Map(
    scrapedClasses.map((entry) => [normalizeClassName(entry.className), entry]),
);
const scrapedByPeriod = new Map(
    scrapedClasses.map((entry) => [entry.period.trim(), entry]),
);

function getClassPoints(className: string, classPeriod: string | null) {
    const normalizedName = normalizeClassName(className);
    const scraped =
        (classPeriod ? scrapedByPeriod.get(classPeriod) : undefined) ??
        scrapedByName.get(normalizedName);
    if (!scraped || !scraped.assignments?.length) {
        return null;
    }

    const totals = scraped.assignments.reduce(
        (acc, assignment) => {
            if (!Number.isFinite(assignment.totalPoints) || assignment.totalPoints <= 0) {
                return acc;
            }
            const earned = assignment.graded ? assignment.earnedPoints : 0;
            return {
                earned: acc.earned + (Number.isFinite(earned) ? earned : 0),
                possible: acc.possible + assignment.totalPoints,
            };
        },
        { earned: 0, possible: 0 },
    );

    if (totals.possible <= 0) {
        return null;
    }

    return totals;
}

const missingAssignments = (missingAssignmentsData as MissingAssignmentsData).missing_assignments?.map(
    (assignment) => {
        const classKey = normalizeClassName(assignment.class_name);
        const classInfo = classLookup.get(classKey);
        const maxPoints = Number(assignment.max_points);
        const classPoints = getClassPoints(
            assignment.class_name,
            classInfo?.period ?? null,
        );
        return {
            assignment: assignment.assignment_name,
            className: assignment.class_name,
            due: normalizeMissingDate(assignment.due_date),
            maxPoints: Number.isFinite(maxPoints) ? maxPoints : 0,
            classGrade: classInfo?.grade ?? null,
            classLetterGrade: classInfo?.lettergrade ?? null,
            classPeriod: classInfo?.period ?? null,
            classPoints,
        };
    },
) ?? [];
const missingAssignmentsCount = missingAssignments.length;

function getGradeColor(grade: number): string {
    if (grade >= 90) return "grade-a";
    if (grade >= 80) return "grade-b";
    if (grade >= 70) return "grade-c";
    if (grade >= 60) return "grade-d";
    return "grade-f";
}

// ── Grade fluctuation (Q4 sparklines + weekly delta) ──────────────────────
const gradeHistory = (gradesData.grade_history ?? {}) as Record<string, Record<string, number>>;

const parseDate = (d: string) => { const p = Date.parse(d); return Number.isNaN(p) ? 0 : p; };

function detectQ4Start(history: Record<string, number>): string | null {
    const entries = Object.entries(history).sort(([a], [b]) => parseDate(a) - parseDate(b));
    if (entries.length === 0) return null;
    for (let i = 1; i < entries.length; i++) {
        if (entries[i - 1][1] > 10 && entries[i][1] === 0) {
            for (let j = i + 1; j < entries.length; j++) {
                if (entries[j][1] > 0) return entries[j][0];
            }
            return entries[i][0];
        }
    }
    return entries[0][0];
}

function buildMiniSparkline(series: { date: string; value: number }[], width = 80, height = 24): string {
    if (series.length < 2) return "";
    const values = series.map((s) => s.value);
    const rawMin = Math.min(...values);
    const rawMax = Math.max(...values);
    const range = rawMax - rawMin;
    const yMin = range < 2 ? Math.max(0, rawMin - 3) : rawMin - 1;
    const yMax = range < 2 ? Math.min(100, rawMax + 3) : rawMax + 1;
    const yRange = yMax - yMin || 1;
    const pad = 2;
    const plotW = width - 2 * pad;
    const plotH = height - 2 * pad;
    return series
        .map((s, i) => {
            const progress = series.length > 1 ? i / (series.length - 1) : 0;
            const x = pad + progress * plotW;
            const y = pad + (1 - (s.value - yMin) / yRange) * plotH;
            return `${x.toFixed(1)},${y.toFixed(1)}`;
        })
        .join(" ");
}

const ONE_DAY_MS = 24 * 60 * 60 * 1000;

interface FluctuationData {
    delta: number;
    sparkPoints: string;
    hasData: boolean;
    prevDate: string;
    lastDate: string;
}

const classFluctuation = new Map<string, FluctuationData>(
    data.map((cls) => {
        const history = gradeHistory[cls.className] ?? {};
        const q4Start = detectQ4Start(history);
        const q4StartTs = q4Start ? parseDate(q4Start) : 0;
        const series = Object.entries(history)
            .sort(([a], [b]) => parseDate(a) - parseDate(b))
            .filter(([date, val]) => parseDate(date) >= q4StartTs && (val as number) > 0)
            .map(([date, value]) => ({ date, value: value as number }));

        if (series.length < 2) {
            return [cls.className, { delta: 0, sparkPoints: "", hasData: false, prevDate: "", lastDate: "" }];
        }
        const last = series[series.length - 1];
        const lastTs = parseDate(last.date);
        const yesterday = [...series].reverse().find((s) => lastTs - parseDate(s.date) >= ONE_DAY_MS);
        const prev = yesterday ?? series[0];
        const delta = last.value - prev.value;
        return [
            cls.className,
            { delta, sparkPoints: buildMiniSparkline(series), hasData: true, prevDate: prev.date, lastDate: last.date },
        ];
    })
);
